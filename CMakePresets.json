{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/linux-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MAKE_PROGRAM": {
          "type": "FILEPATH",
          "value": "${sourceDir}/out/bootstrap/ninja/ninja"
        },
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VOLKENGINE_ENABLE_VALIDATION": "ON"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/linux-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MAKE_PROGRAM": {
          "type": "FILEPATH",
          "value": "${sourceDir}/out/bootstrap/ninja/ninja"
        },
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VOLKENGINE_ENABLE_VALIDATION": "OFF"
      }
    },
    {
      "name": "linux-sanitize",
      "displayName": "Linux ASan and UBSan",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/linux-sanitize",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MAKE_PROGRAM": {
          "type": "FILEPATH",
          "value": "${sourceDir}/out/bootstrap/ninja/ninja"
        },
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VOLKENGINE_ENABLE_VALIDATION": "OFF",
        "VOLKENGINE_ENABLE_IMGUI": "OFF",
        "VOLKENGINE_ENABLE_SANITIZERS": "ON",
        "VOLKENGINE_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/windows-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MAKE_PROGRAM": {
          "type": "FILEPATH",
          "value": "${sourceDir}/out/bootstrap/ninja/ninja.exe"
        },
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VOLKENGINE_ENABLE_VALIDATION": "ON"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/windows-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MAKE_PROGRAM": {
          "type": "FILEPATH",
          "value": "${sourceDir}/out/bootstrap/ninja/ninja.exe"
        },
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VOLKENGINE_ENABLE_VALIDATION": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-sanitize",
      "configurePreset": "linux-sanitize",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "targets": [
        "VolkEngineConfigCpuTest",
        "VolkEngineRunSummaryCpuTest",
        "VolkEngineAssetPipelineCpuTest",
        "VolkEngineVulkanFrameGraphSyncCpuTest",
        "VolkEngineVulkanReadbackStateCpuTest",
        "VolkEngineSceneRendererTest",
        "VolkEngineWorldSceneCpuTest",
        "VolkEngineScenePersistenceCpuTest",
        "VolkEngineWorldSchedulerCpuTest",
        "VolkEngineFrameGraphCpuTest",
        "VolkEngineImageLoaderCpuTest",
        "VolkEngineGeometryCpuTest",
        "VolkEngineGreedyMesherCpuTest",
        "VolkEngineGpuResourceRegistryCpuTest",
        "VolkEngineMathCpuTest",
        "VolkEngineVulkanFrustumCpuTest",
        "VolkEngineCameraCpuTest",
        "VolkEngineInputCpuTest",
        "VolkEnginePlatformLifecycleCpuTest",
        "VolkEngineTimeCpuTest",
        "VolkEngineWorldCpuTest"
      ]
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "testPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "linux-sanitize",
      "configurePreset": "linux-sanitize",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "filter": {
        "exclude": {
          "name": "SandboxHelp"
        }
      },
      "environment": {
        "ASAN_OPTIONS": "detect_leaks=1:strict_string_checks=1:check_initialization_order=1",
        "UBSAN_OPTIONS": "print_stacktrace=1:halt_on_error=1"
      },
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    }
  ]
}
